{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run current TS file",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
        }
    ]
}