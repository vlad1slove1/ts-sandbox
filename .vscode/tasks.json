{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run current TS file",
            "type": "shell",
            "command": "${workspaceFolder}/node_modules/.bin/tsx",
            "args": ["${file}"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
